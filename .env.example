# ════════════════════════════════════════════════════════════════════
# Credenciais Databricks
# Configure os valores reais nos Codespaces Secrets (nunca commite este arquivo!)
# github.com → Settings → Codespaces → Secrets
# ════════════════════════════════════════════════════════════════════

# URL do seu workspace Databricks Free Edition
DATABRICKS_HOST=${DATABRICKS_HOST}

# Personal Access Token gerado em Settings → Developer → Access Tokens
DATABRICKS_TOKEN=${DATABRICKS_TOKEN}

# ID do cluster criado para o treinamento
# Encontre em: Compute → seu cluster → JSON → cluster_id
DATABRICKS_CLUSTER_ID=${DATABRICKS_CLUSTER_ID}

# ── Volume Unity Catalog (VOLUME_RAW_PATH é computado pelo Makefile) ─
VOLUME_CATALOG=workspace
VOLUME_SCHEMA=training_sql_serverless
VOLUME_NAME=raw_files

# ── Configurações PySpark local ───────────────────────────────────
SPARK_LOCAL_IP=127.0.0.1
PYSPARK_PYTHON=/usr/local/bin/python3
