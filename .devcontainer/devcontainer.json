{
  "name": "Databricks + Copilot Training",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // ── Variáveis de ambiente (configure nos Codespaces Secrets) ─────────────────────────
  // github.com/<org>/<repo>/settings/secrets/codespaces
  "containerEnv": {
    "DATABRICKS_HOST": "${localEnv:DATABRICKS_HOST}",
    "DATABRICKS_TOKEN": "${localEnv:DATABRICKS_TOKEN}",
    "DATABRICKS_CLUSTER_ID": "${localEnv:DATABRICKS_CLUSTER_ID}",
    "SPARK_LOCAL_IP": "127.0.0.1",
    "PYSPARK_PYTHON": "/usr/local/bin/python3"
  },

  // ── Extensões VS Code pré-instaladas ────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        // Databricks
        "databricks.databricks",

        // GitHub Copilot
        "GitHub.copilot",
        "GitHub.copilot-chat",

        // Python
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.mypy-type-checker",

        // Notebooks & Data
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ],

      // ── Configurações do VS Code ────────────────────────────────────────
      "settings": {
        // Editor
        "editor.formatOnSave": true,
        "editor.rulers": [88, 120],
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.renderWhitespace": "boundary",
        "editor.suggestSelection": "first",
        "editor.inlineSuggest.enabled": true,
        "editor.acceptSuggestionOnEnter": "smart",

        // Python
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "black-formatter.args": ["--line-length", "88"],
        "isort.args": ["--profile", "black"],

        // Copilot
        "github.copilot.enable": {
          "*": true,
          "python": true,
          "sql": true,
          "yaml": true,
          "markdown": true,
          "shellscript": true
        },
        "github.copilot.editor.enableAutoCompletions": true,
        "github.copilot.chat.localeOverride": "pt-BR",

        // Databricks
        "databricks.python.envFile": "${workspaceFolder}/.env",

        // Jupyter
        "jupyter.interactiveWindow.textEditor.executeSelection": true,
        "jupyter.notebookFileRoot": "${workspaceFolder}",

        // Terminal
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.fontSize": 14,

        // Arquivos
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/*.pyc": true,
          "**/data/processed/**": true
        },
        "files.associations": {
          "*.py": "python",
          "*.sql": "sql",
          "*.yml": "yaml",
          "*.yaml": "yaml"
        }
      }
    }
  },

  // ── Scripts de ciclo de vida ────────────────────────────────────────────
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",

  // ── Portas expostas ─────────────────────────────────────────────────────
  "forwardPorts": [
    4040   // Spark UI (execução local)
  ],
  "portsAttributes": {
    "4040": {
      "label": "Spark UI",
      "onAutoForward": "notify"
    }
  },

  // ── Usuário e capacidades do container ─────────────────────────────────
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  }
}
